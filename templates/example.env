# Required environment variables for this service.
#
# Single-file layout — copy this file to:
#   .env/local.env    (local dev, gitignored)
#   .env/test.env     (test, gitignored)
#
# Directory layout — split by concern, copy into:
#   .env/local/app.env   .env/local/db.env   …
#   .env/test/app.env    .env/test/db.env    …
#
# direnv picks up whichever layout is present (see templates/envrc).

SERVER_PORT=8080

# Database (example — add actual vars after running spec-delta)
DATABASE_URL=
