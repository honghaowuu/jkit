#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# JSON string escaping — pure bash, no Python dependency
# Same technique as superpowers session-start.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# 1. Install direnv if missing
if ! command -v direnv &>/dev/null; then
  echo "jkit: direnv not found — installing..." >&2
  curl -sfL https://direnv.net/install.sh | bash 2>/dev/null \
    || echo "jkit: direnv install failed. Install manually: https://direnv.net" >&2
fi

# 2. Allow .envrc (idempotent — keyed by .envrc hash, silent no-op when already allowed)
if command -v direnv &>/dev/null && [ -f ".envrc" ]; then
  direnv allow . 2>/dev/null || true
fi

# 3. Validate bundled CLIs
for b in jkit kit codeskel; do
  if [ ! -x "${PLUGIN_ROOT}/bin/$b" ]; then
    echo "jkit: bin/$b missing or not executable. Run: chmod +x \"${PLUGIN_ROOT}/bin/\"*" >&2
  fi
done

# 4. Conditional context injection.
# A project is jkit-managed iff it tracks pending change descriptions under
# docs/changes/. If absent but the project looks Java-y (pom.xml present),
# nudge the human towards /migrate-project. Otherwise stay silent.
if [ ! -d "docs/changes" ]; then
  if [ -f "pom.xml" ] || [ -f "build.gradle" ] || [ -f "build.gradle.kts" ]; then
    NUDGE="<jkit-onboarding-hint>This looks like a Java project but isn't bootstrapped for the jkit spec-delta workflow yet. Run \`/migrate-project\` to create \`docs/changes/{pending,done}/\` and see how to write your first change file.</jkit-onboarding-hint>"
    nudge_escaped=$(escape_for_json "$NUDGE")
    if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
      printf '{"additional_context": "%s"}\n' "$nudge_escaped"
    elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
      printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$nudge_escaped"
    else
      printf '{"additionalContext": "%s"}\n' "$nudge_escaped"
    fi
    exit 0
  fi
  printf '{}\n'
  exit 0
fi

CONTEXT=$(cat "${PLUGIN_ROOT}/hooks/jkit-context.md")

# 5. Ensure superpowers plugin is installed (required by /write-change and /spec-delta).
# Pre-authorized: install silently if missing; activates next session.
# Stderr surfaces failures but never blocks context emission.
if ! find "${HOME}/.claude/plugins" -path '*superpowers*brainstorming*SKILL.md' -print -quit 2>/dev/null | grep -q .; then
  if command -v claude &>/dev/null; then
    if ! claude plugin marketplace list 2>/dev/null | grep -q 'claude-plugins-official'; then
      claude plugin marketplace add anthropics/claude-plugins-official --scope project >/dev/null 2>&1 \
        || echo "jkit: failed to add claude-plugins-official marketplace" >&2
    fi
    claude plugin install superpowers@claude-plugins-official --scope project >/dev/null 2>&1 \
      || echo "jkit: failed to install superpowers plugin via 'claude plugin install'" >&2
  else
    echo "jkit: 'claude' CLI not on PATH — cannot auto-install superpowers plugin" >&2
  fi
fi

# 6. Append marketplace catalog if present (zero network calls — reads local cache only)
if [ -f ".jkit/marketplace-catalog.json" ]; then
  CATALOG_BLOCK=$(python3 - <<'PYEOF'
import json, sys
with open(".jkit/marketplace-catalog.json") as f:
    data = json.load(f)
contracts = data.get("contracts", [])
if not contracts:
    sys.exit(0)
lines = ["\n## Available Service Contracts\n"]
installed = set()
try:
    with open("contracts.json") as cf:
        installed = set(json.load(cf).get("dependencies", []))
except FileNotFoundError:
    pass
for c in contracts:
    name = c["name"]
    desc = c["description"]
    lines.append(f"{name} — {desc}")
installed_names = [c["name"] for c in contracts if c["name"] in installed]
not_installed_names = [c["name"] for c in contracts if c["name"] not in installed]
if installed_names:
    lines.append(f"\nInstalled in this project: {', '.join(installed_names)}")
if not_installed_names:
    lines.append(f"Not yet installed: {', '.join(not_installed_names)}")
print("\n".join(lines))
PYEOF
  )
  CONTEXT="${CONTEXT}${CATALOG_BLOCK}"
fi

context_escaped=$(escape_for_json "$CONTEXT")

# Platform detection — emit only the field the current platform consumes
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor
  printf '{"additional_context": "%s"}\n' "$context_escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$context_escaped"
else
  # Copilot CLI / SDK fallback
  printf '{"additionalContext": "%s"}\n' "$context_escaped"
fi
exit 0
